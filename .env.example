# Optional local path overrides. These are not secrets.
#
# Keeping config, data, and reports outside the repository reduces the chance of
# committing generated databases or reports by accident.

# Directory containing sources.yaml, entities.yaml, and scoring.yaml.
FASHION_RADAR_CONFIG_DIR=

# Directory containing the local fashion-radar.sqlite runtime database.
FASHION_RADAR_DATA_DIR=

# Directory where Markdown and JSON reports are written.
FASHION_RADAR_REPORTS_DIR=
